        };
        document.querySelectorAll('#tabla-areas-ausol tbody tr').forEach(row => {
            datos.areasAusol.push({ estado: row.cells[2].querySelector('select').value, plazo: row.cells[3].querySelector('input').value, puestos: row.cells[4].querySelector('input').value, ingreso: row.cells[5].querySelector('input').value });
        });
        document.querySelectorAll('#tabla-areas-gco tbody tr').forEach(row => {
            datos.areasGco.push({ estado: row.cells[2].querySelector('select').value, plazo: row.cells[3].querySelector('input').value, puestos: row.cells[4].querySelector('input').value, ingreso: row.cells[5].querySelector('input').value });
        });
        document.querySelectorAll('#tabla-cercania-ausol tbody tr').forEach(row => {
            datos.cercaniaAusol.push({ estado: row.cells[1].querySelector('select').value, plazo: row.cells[2].querySelector('input').value, puestos: row.cells[3].querySelector('input').value, ingreso: row.cells[4].querySelector('input').value });
        });
        document.querySelectorAll('#tabla-cercania-gco tbody tr').forEach(row => {
            datos.cercaniaGco.push({ estado: row.cells[1].querySelector('select').value, plazo: row.cells[2].querySelector('input').value, puestos: row.cells[3].querySelector('input').value, ingreso: row.cells[4].querySelector('input').value });
        });
        document.querySelectorAll('#tabla-fibra tbody tr').forEach(row => {
            datos.fibra.push({ estado: row.cells[1].querySelector('select').value, avance: row.cells[2].querySelector('input').value });
        });
        document.querySelectorAll('#tabla-publicidad tbody tr').forEach(row => {
            datos.publicidad.push({ estado: row.cells[1].querySelector('select').value, avance: row.cells[2].querySelector('input').value });
        });
        localStorage.setItem('tableroDatos', JSON.stringify(datos));
    }

    function cargarDatos() {
        const guardado = localStorage.getItem('tableroDatos');
        if (!guardado) return;
        const datos = JSON.parse(guardado);
        let idx = 0;
        document.querySelectorAll('#tabla-areas-ausol tbody tr').forEach(row => {
            if (datos.areasAusol[idx]) { row.cells[2].querySelector('select').value = datos.areasAusol[idx].estado; row.cells[3].querySelector('input').value = datos.areasAusol[idx].plazo; row.cells[4].querySelector('input').value = datos.areasAusol[idx].puestos; row.cells[5].querySelector('input').value = datos.areasAusol[idx].ingreso; }
            idx++;
        });
        idx = 0;
        document.querySelectorAll('#tabla-areas-gco tbody tr').forEach(row => {
            if (datos.areasGco[idx]) { row.cells[2].querySelector('select').value = datos.areasGco[idx].estado; row.cells[3].querySelector('input').value = datos.areasGco[idx].plazo; row.cells[4].querySelector('input').value = datos.areasGco[idx].puestos; row.cells[5].querySelector('input').value = datos.areasGco[idx].ingreso; }
            idx++;
        });
        idx = 0;
        document.querySelectorAll('#tabla-cercania-ausol tbody tr').forEach(row => {
            if (datos.cercaniaAusol[idx]) { row.cells[1].querySelector('select').value = datos.cercaniaAusol[idx].estado; row.cells[2].querySelector('input').value = datos.cercaniaAusol[idx].plazo; row.cells[3].querySelector('input').value = datos.cercaniaAusol[idx].puestos; row.cells[4].querySelector('input').value = datos.cercaniaAusol[idx].ingreso; }
            idx++;
        });
        idx = 0;
        document.querySelectorAll('#tabla-cercania-gco tbody tr').forEach(row => {
            if (datos.cercaniaGco[idx]) { row.cells[1].querySelector('select').value = datos.cercaniaGco[idx].estado; row.cells[2].querySelector('input').value = datos.cercaniaGco[idx].plazo; row.cells[3].querySelector('input').value = datos.cercaniaGco[idx].puestos; row.cells[4].querySelector('input').value = datos.cercaniaGco[idx].ingreso; }
            idx++;
        });
        idx = 0;
        document.querySelectorAll('#tabla-fibra tbody tr').forEach(row => {
            if (datos.fibra[idx]) { row.cells[1].querySelector('select').value = datos.fibra[idx].estado; row.cells[2].querySelector('input').value = datos.fibra[idx].avance; }
            idx++;
        });
        idx = 0;
        document.querySelectorAll('#tabla-publicidad tbody tr').forEach(row => {
            if (datos.publicidad[idx]) { row.cells[1].querySelector('select').value = datos.publicidad[idx].estado; row.cells[2].querySelector('input').value = datos.publicidad[idx].avance; }
            idx++;
        });
        if (datos.kpis) { if (document.getElementById('kpi-ingreso')) document.getElementById('kpi-ingreso').value = datos.kpis.ingreso; }
    }

    // Actualizar resumen
    function actualizarResumen() {
        let ausolIngreso = 0, gcoIngreso = 0, ausolCercIngreso = 0, gcoCercIngreso = 0;
        document.querySelectorAll('#tabla-areas-ausol tbody tr').forEach(row => { ausolIngreso += parseFloat(row.cells[5]?.querySelector('input')?.value) || 0; });
        document.querySelectorAll('#tabla-areas-gco tbody tr').forEach(row => { gcoIngreso += parseFloat(row.cells[5]?.querySelector('input')?.value) || 0; });
        document.querySelectorAll('#tabla-cercania-ausol tbody tr').forEach(row => { ausolCercIngreso += parseFloat(row.cells[4]?.querySelector('input')?.value) || 0; });
        document.querySelectorAll('#tabla-cercania-gco tbody tr').forEach(row => { gcoCercIngreso += parseFloat(row.cells[4]?.querySelector('input')?.value) || 0; });
        document.getElementById('ausol-ingreso').innerText = ausolIngreso.toLocaleString();
        document.getElementById('gco-ingreso').innerText = gcoIngreso.toLocaleString();
        document.getElementById('ausol-ingreso-cerc').innerText = ausolCercIngreso.toLocaleString();
        document.getElementById('gco-ingreso-cerc').innerText = gcoCercIngreso.toLocaleString();
        const totalIngreso = ausolIngreso + gcoIngreso + ausolCercIngreso + gcoCercIngreso;
        document.getElementById('total-ingreso').innerHTML = `USD ${(totalIngreso/1000000).toFixed(2)}MM`;
    }

    // Exportar funciones
    function exportarTabla(nombreHoja, tablaId, nombreArchivo) {
        const tabla = document.getElementById(tablaId);
        const wb = XLSX.utils.book_new();
        const ws = XLSX.utils.table_to_sheet(tabla, { raw: true });
        XLSX.utils.book_append_sheet(wb, ws, nombreHoja);
        XLSX.writeFile(wb, nombreArchivo);
    }

    document.getElementById('exportExcel').addEventListener('click', () => exportarTabla('Resumen', 'resumen table', 'Resumen_Ejecutivo.xlsx'));
    document.getElementById('exportAreasExcel').addEventListener('click', () => exportarTabla('AreasServicio', 'tabla-areas-ausol', 'Areas_Servicio_AUSOL.xlsx'));
    document.getElementById('exportCercaniaExcel').addEventListener('click', () => exportarTabla('EspaciosCercania', 'tabla-cercania-ausol', 'Espacios_Cercania.xlsx'));
    document.getElementById('exportFibraExcel').addEventListener('click', () => exportarTabla('FibraOptica', 'tabla-fibra', 'Fibra_Optica.xlsx'));
    document.getElementById('exportPublicidadExcel').addEventListener('click', () => exportarTabla('PublicidadVial', 'tabla-publicidad', 'Publicidad_Vial.xlsx'));
    document.getElementById('exportKPIsExcel').addEventListener('click', () => exportarTabla('KPIs', 'tabla-kpis', 'KPIs_Financieros.xlsx'));

    document.querySelectorAll('input, select').forEach(el => el.addEventListener('change', () => { guardarTodo(); actualizarResumen(); }));
    cargarDatos();
    actualizarResumen();

    // Navegación
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById(btn.getAttribute('data-tab')).classList.add('active');
        });
    });
</script>
</body>
</html>
